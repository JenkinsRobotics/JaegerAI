#!/bin/bash
# jaeger — the operator command (the one thing you run).
#
# Dispatches:
#   jaeger                      run the ACTIVE agent (no --instance needed)
#   jaeger --instance NAME      run a specific agent
#   jaeger --voice ...          run the agent in voice mode
#   jaeger --dev [flag]         boot the dev instance's in-process TUI
#                               (delegates to launch.py: bare → --tui,
#                               or pass --stop/--restart/--status/--health)
#   jaeger instances ...        manage agents: list / create / edit /
#                               delete / set-default / show
#   jaeger skills|personality|status|roadmap|avatar    operator console
#   jaeger setup [name]         alias of `jaeger instances create`
#   jaeger doctor               environment + readiness check
#
# Management subcommands go to the console (jaeger_os.cli); everything
# else runs the agent (jaeger_os.cli.run). Picks the repo's .venv interpreter
# directly to sidestep pyenv shims (same pattern as ./launch).
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PY="$REPO_ROOT/.venv/bin/python"

if [ ! -x "$VENV_PY" ]; then
  echo "[jaeger] $VENV_PY not found — run ./install.sh first" >&2
  exit 1
fi

case "${1:-}" in
  instances|skills|personality|status|roadmap|avatar|prompt|config)
    exec "$VENV_PY" -m jaeger_os.cli "$@" ;;
  setup)
    shift; exec "$VENV_PY" -m jaeger_os.cli instances create "$@" ;;
  bridge)
    # Headless NDJSON stdio bridge — spawned by the native (Swift) app
    # to drive the agent out of process. Not for interactive use.
    shift; exec "$VENV_PY" -m jaeger_os.interfaces.bridge "$@" ;;
  mcp)
    # Expose JROS as an MCP server (stdio) so Claude Code / Cursor / Zed
    # can drive the agent as a tool. Spawned by the MCP client.
    shift; exec "$VENV_PY" -m jaeger_os.interfaces.mcp_server "$@" ;;
  doctor)
    shift; exec "$VENV_PY" -m jaeger_os.cli.run --doctor "$@" ;;
  --dev)
    # Dev TUI on the gitignored dev instance, via the launch.py machinery
    # (singleton lock, --stop/--restart/--status/--health). Bare → --tui.
    shift; [ $# -eq 0 ] && set -- --tui
    exec "$VENV_PY" "$REPO_ROOT/launch.py" "$@" ;;
  help|--help|-h)
    exec "$VENV_PY" -m jaeger_os.cli --help ;;
  *)
    # bare, --instance, --voice, a one-shot prompt, … → run the agent
    exec "$VENV_PY" -m jaeger_os.cli.run "$@" ;;
esac
