#!/bin/bash
# jaeger — the operator command (the one thing you run).
#
# Dispatches:
#   jaeger                      run the ACTIVE agent (no --instance needed)
#   jaeger --instance NAME      run a specific agent
#   jaeger --voice ...          run the agent in voice mode
#   jaeger dev [flag]           developer toolbox (jaeger_ai.cli.devtools):
#                               dev app/TUI boot, or pass
#                               --stop/--status/--health/--dev-gui/…
#   jaeger instances ...        manage agents: list / create / edit /
#                               delete / set-default / show
#   jaeger skills|personality|status|roadmap|avatar    operator console
#   jaeger setup [name]         alias of `jaeger instances create`
#   jaeger doctor               environment + readiness check
#
# Management subcommands go to the console (jaeger_ai.cli); everything
# else runs the agent (jaeger_ai.cli.run). Picks the repo's .venv interpreter
# directly to sidestep pyenv shims.
set -euo pipefail

# Resolve symlinks (install.sh links /usr/local/bin/jaeger → here) so
# REPO_ROOT is the real install dir, not the symlink's.
SELF="${BASH_SOURCE[0]}"
while [ -L "$SELF" ]; do
  DIR="$(cd "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  [[ "$SELF" != /* ]] && SELF="$DIR/$SELF"
done
REPO_ROOT="$(cd "$(dirname "$SELF")" && pwd)"
VENV_PY="$REPO_ROOT/.venv/bin/python"

if [ ! -x "$VENV_PY" ]; then
  echo "[jaeger] $VENV_PY not found — run ./install.sh first" >&2
  exit 1
fi

# Dispatch now lives in jaeger_ai.cli.entry — ONE routing table behind both
# this wrapper and the installed `jaeger` console script. It re-execs the same
# `python -m <module>` (or launch.py) targets this case statement used to, so
# behaviour is unchanged; see jaeger_ai/cli/entry.py:_route for the table.
exec "$VENV_PY" -m jaeger_ai.cli.entry "$@"
